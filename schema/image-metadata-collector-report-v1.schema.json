{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SDA-SE/image-metadata-collector/schema/image-metadata-collector-report-v1.schema.json",
  "title": "Image Metadata Collector Report v1",
  "description": "Schema for the JSON array uploaded by the image metadata collector to API, S3, or filesystem storage.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schema_version",
      "namespace",
      "image",
      "image_id",
      "image_type",
      "environment",
      "product",
      "description",
      "app_kubernetes_io_name",
      "app_kubernetes_io_version",
      "container_type",
      "skip",
      "namespace_filter",
      "namespace_filter_negated",
      "engagement_tags",
      "team",
      "owners",
      "notifications",
      "is_scan_baseimage_lifetime",
      "is_scan_dependency_check",
      "is_scan_dependency_track",
      "is_scan_distroless",
      "is_scan_lifetime",
      "is_scan_malware",
      "is_scan_new_version",
      "is_scan_runasroot",
      "is_scan_potentially_running_as_root",
      "is_scan_run_as_privileged",
      "is_scan_potentially_running_as_privileged",
      "scan_lifetime_max_days"
    ],
    "properties": {
      "schema_version": {
        "type": "string",
        "enum": ["v1"],
        "description": "Payload contract version for each image element."
      },
      "namespace": {
        "type": "string"
      },
      "image": {
        "type": "string"
      },
      "image_id": {
        "type": "string"
      },
      "image_type": {
        "type": "string"
      },
      "environment": {
        "type": "string"
      },
      "product": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "app_kubernetes_io_name": {
        "type": "string"
      },
      "app_kubernetes_io_version": {
        "type": "string"
      },
      "container_type": {
        "type": "string"
      },
      "skip": {
        "type": "boolean"
      },
      "namespace_filter": {
        "type": "string"
      },
      "namespace_filter_negated": {
        "type": "string"
      },
      "engagement_tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "team": {
        "type": "string"
      },
      "owners": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role",
            "uuid",
            "name"
          ],
          "properties": {
            "role": {
              "type": "string"
            },
            "uuid": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          }
        }
      },
      "notifications": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slack",
          "emails",
          "ms_teams"
        ],
        "properties": {
          "slack": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ms_teams": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "is_scan_baseimage_lifetime": {
        "type": "boolean"
      },
      "is_scan_dependency_check": {
        "type": "boolean"
      },
      "is_scan_dependency_track": {
        "type": "boolean"
      },
      "is_scan_distroless": {
        "type": "boolean"
      },
      "is_scan_lifetime": {
        "type": "boolean"
      },
      "is_scan_malware": {
        "type": "boolean"
      },
      "is_scan_new_version": {
        "type": "boolean"
      },
      "is_scan_runasroot": {
        "type": "boolean"
      },
      "is_scan_potentially_running_as_root": {
        "type": "boolean"
      },
      "is_scan_run_as_privileged": {
        "type": "boolean"
      },
      "is_scan_potentially_running_as_privileged": {
        "type": "boolean"
      },
      "scan_lifetime_max_days": {
        "type": "integer"
      }
    }
  }
}
